APP_NAME="Dashboard Monitoring PG Madukismo"
APP_ENV=production
APP_DEBUG=false
APP_URL=https://your-domain.example

# Wajib isi APP_KEY hasil dari: php artisan key:generate --show
APP_KEY=

LOG_CHANNEL=stack
LOG_LEVEL=info
SESSION_DRIVER=file
CACHE_STORE=file
QUEUE_CONNECTION=sync

# Default koneksi utama aplikasi
DB_CONNECTION=pgsql

# PostgreSQL (server existing)
DB_PGSQL_HOST=your_pgsql_host
DB_PGSQL_PORT=5432
DB_PGSQL_DATABASE=madukismo_system
DB_PGSQL_USERNAME=your_pg_user
DB_PGSQL_PASSWORD=your_pg_password

# SQL Server (server existing)
DB_SQLSRV_HOST=your_sqlsrv_host
DB_SQLSRV_PORT=1433
DB_SQLSRV_DATABASE=TIMB_MK
DB_SQLSRV_USERNAME=sa
DB_SQLSRV_PASSWORD=your_sqlsrv_password
DB_SQLSRV_ENCRYPT=yes
DB_SQLSRV_TRUST_CERT=false

# Opsional Vite runtime
VITE_APP_URL=https://your-domain.example
VITE_DEV_SERVER_URL=

# Opsional untuk ubah port host container app
APP_PORT=8000

# Opsional jika image dibuild CI/CD lalu dipull
# APP_IMAGE=ghcr.io/afdi18/pg-madukismo:latest
