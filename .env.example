APP_NAME="Dashboard Monitoring PG Madukismo"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000
APP_TIMEZONE=Asia/Jakarta
APP_LOCALE=id
APP_FALLBACK_LOCALE=id

LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# ============================================================
# DATABASE UTAMA — PostgreSQL
# User, Roles, Permissions (ABAC), Peta Kebun, Lab QA, Sistem
# ============================================================
DB_CONNECTION=pgsql
DB_PGSQL_HOST=127.0.0.1
DB_PGSQL_PORT=5432
DB_PGSQL_DATABASE=madukismo_system
DB_PGSQL_USERNAME=postgres
DB_PGSQL_PASSWORD=

# ============================================================
# DATABASE KEDUA — SQL Server
# Dashboard Tanaman, Data Produksi, KPI, Rendemen
#
# ODBC Driver yang dibutuhkan:
#   SQL Server 2014 → ODBC Driver 11 atau 13 for SQL Server
#   SQL Server 2017 → ODBC Driver 17 for SQL Server (direkomendasikan)
#   SQL Server 2019+ → ODBC Driver 18 for SQL Server
#
# Cek driver terpasang: odbcinst -q -d (Linux) atau
#   HKLM\SOFTWARE\ODBC\ODBCINST.INI (Windows)
# ============================================================
DB_SQLSRV_HOST=localhost
DB_SQLSRV_PORT=1433
DB_SQLSRV_DATABASE=madukismo_tanaman
DB_SQLSRV_USERNAME=sa
DB_SQLSRV_PASSWORD=
# Untuk SQL Server 2014: set ENCRYPT=no jika belum patch KB3052404 (TLS 1.2)
# Untuk SQL Server 2017+: ENCRYPT=yes aman digunakan
DB_SQLSRV_ENCRYPT=yes
DB_SQLSRV_TRUST_CERT=false

# ============================================================
# SESSION & CACHE
# ============================================================
SESSION_DRIVER=database
SESSION_LIFETIME=480
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database
CACHE_STORE=database

# ============================================================
# MAIL
# ============================================================
MAIL_MAILER=log
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="noreply@madukismo.co.id"
MAIL_FROM_NAME="${APP_NAME}"

# ============================================================
# VITE
# ============================================================
VITE_APP_NAME="${APP_NAME}"
VITE_APP_URL="${APP_URL}"
VITE_DEV_SERVER_URL=
VITE_GEOSERVER_BASE_URL=
VITE_GEOSERVER_WORKSPACE=petakebun
VITE_GEOSERVER_LAYER=master_madubaru
